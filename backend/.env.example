# Copiaza acest fisier in .env si completeaza valorile

# Genereaza cu: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=genereaza_o_cheie_secreta_aici
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://USER:PAROLA@localhost:5432/BAZA_DE_DATE

# CORS
CORS_ORIGINS=["http://localhost:5173"]

# Rate Limiting
RATE_LIMIT_LOGIN=5/minute

# Cookie
COOKIE_SECURE=False
DEBUG=True
